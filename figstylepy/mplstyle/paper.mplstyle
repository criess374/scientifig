axes.axisbelow: True
axes.edgecolor: .8
axes.facecolor: white
axes.grid: True
axes.labelcolor: .15
axes.linewidth: 1.0
figure.facecolor: white
savefig.facecolor: white
savefig.edgecolor: white
grid.color: .8
grid.linestyle: -
image.cmap: Greys
legend.frameon: True
legend.numpoints: 1
legend.scatterpoints: 1
lines.solid_capstyle: round
text.color: .15
xtick.color: .15
xtick.direction: out
xtick.major.size: 0.0
xtick.minor.size: 0.0
ytick.color: .15
ytick.direction: out
ytick.major.size: 0.0
ytick.minor.size: 0.0

savefig.dpi    : 300
axes.titlesize : 18
axes.labelsize : 15
lines.linewidth : 2
lines.markersize : 8
legend.fontsize : 10
xtick.labelsize : 12
ytick.labelsize : 12
